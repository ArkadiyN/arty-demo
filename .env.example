# Elsevier Developer API Credentials
ELSEVIER_API_KEY='your_elsevier_api_key_here' # pragma: allowlist secret

# AI credentials for the PDF vision processor (src/utils/pdf-processor.py).
# Only one is required — checked in this order: GOOGLE_API_KEY, then
# ANTHROPIC_API_KEY, then OPENROUTER_API_KEY.
# ANTHROPIC_API_KEY must be a real API key (sk-ant-api...), not a Claude Code
# OAuth token (sk-ant-oat01-...) — the API rejects OAuth tokens.
GOOGLE_API_KEY='your_google_api_key_here' # pragma: allowlist secret
GOOGLE_MODEL=gemma-4-31b-it
GOOGLE_TIMEOUT_MS=120000
ANTHROPIC_API_KEY='your_anthropic_api_key_here' # pragma: allowlist secret
OPENROUTER_API_KEY='your_openrouter_api_key_here' # pragma: allowlist secret
OPENROUTER_MODEL=openrouter/free

# Quarto — point at the project venv so notebooks use installed packages
QUARTO_PYTHON=.venv/bin/python